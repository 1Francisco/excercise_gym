<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/quick_widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@drawable/widget_bg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚡ Acceso Rápido"
        android:textColor="#10b981"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="3">

        <LinearLayout
            android:id="@+id/quick_workout_btn"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginRight="4dp"
            android:gravity="center"
            android:orientation="vertical"
            android:background="#10b981"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏋️"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entrenar"
                android:textColor="#fff"
                android:textSize="8sp"
                android:textStyle="bold"
                android:layout_marginTop="1dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/quick_water_btn"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginRight="4dp"
            android:gravity="center"
            android:orientation="vertical"
            android:background="#3b82f6"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💧"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agua"
                android:textColor="#fff"
                android:textSize="8sp"
                android:textStyle="bold"
                android:layout_marginTop="1dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/quick_scan_btn"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="#a855f7"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📷"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Escanear"
                android:textColor="#fff"
                android:textSize="8sp"
                android:textStyle="bold"
                android:layout_marginTop="1dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
